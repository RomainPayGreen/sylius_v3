{#
 # Renders the PayGreen "eligible for meal vouchers" checkbox on the product
 # variant form. Used by both Sylius 1.x UI template events and Sylius 2.x
 # Twig hooks; the guard keeps it safe when the field is absent (e.g. the
 # ProductVariant entity does not implement MealVoucherAwareInterface).
 #}
{% if form is defined and form.mealVoucherCompatible is defined %}
    {{ form_row(form.mealVoucherCompatible) }}
{% endif %}
