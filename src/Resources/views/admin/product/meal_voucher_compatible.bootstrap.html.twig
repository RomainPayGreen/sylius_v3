{#
 # Sylius 2.x (Bootstrap admin) variant of the PayGreen meal voucher section
 # for simple products (default variant exposed as `form.variant`), rendered
 # through Twig hooks. Mirrors the Sylius 1.x Semantic UI segment using a
 # Bootstrap card.
 #}
{% if form is defined and form.variant is defined and form.variant.mealVoucherCompatible is defined %}
    <div class="card mb-3">
        <div class="card-header">PayGreen</div>
        <div class="card-body">
            {{ form_row(form.variant.mealVoucherCompatible) }}
        </div>
    </div>
{% endif %}
