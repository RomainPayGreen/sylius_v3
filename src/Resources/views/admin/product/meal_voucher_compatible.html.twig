{#
 # Renders the PayGreen "eligible for meal vouchers" checkbox on the product
 # form for simple products (where Sylius embeds the default variant as
 # `form.variant`), wrapped in a dedicated PayGreen section so it stays clearly
 # identifiable when other plugins add their own meal voucher fields.
 #
 # Guarded so it renders nothing for configurable products or when the variant
 # is not MealVoucherAwareInterface.
 #}
{% if form is defined and form.variant is defined and form.variant.mealVoucherCompatible is defined %}
    <div class="ui segment">
        <h4 class="ui dividing header">PayGreen</h4>
        {{ form_row(form.variant.mealVoucherCompatible) }}
    </div>
{% endif %}
