{
    "name": "paygreen/sylius-payum-plugin",
    "description": "Sylius Payum integration for PayGreen hosted payment page using the official PayGreen PHP SDK.",
    "type": "sylius-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "paygreen/paygreen-php": "^1.4",
        "php-http/discovery": "^1.19",
        "payum/core": "^1.7",
        "sylius/sylius": "^1.14 || ^2.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/routing": "^6.4 || ^7.0",
        "symfony/validator": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "php-http/message-factory": "^1.1",
        "nyholm/psr7": "^1.8"
    },
    "suggest": {
        "php-http/curl-client": "Provides an HTTPlug HTTP client implementation discoverable by the PayGreen SDK client factory."
    },
    "autoload": {
        "psr-4": {
            "PayGreen\\SyliusPayumPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PayGreen\\SyliusPayumPlugin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "6.4.* || 7.0.*"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        },
        "sort-packages": true
    }
}
